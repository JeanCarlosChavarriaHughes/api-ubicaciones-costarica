# Server
PORT=3000
# Interface to bind (default 0.0.0.0 = all IPv4 interfaces, for LAN/internet). Use 127.0.0.1 for local-only.
# LISTEN_HOST=0.0.0.0

# Optional HTTPS (both required to enable TLS). If unset, the app serves plain HTTP only.
# Use real paths to PEM files. See docs/README.md → HTTPS.
# HTTPS_KEY_PATH=./certs/localhost-key.pem
# HTTPS_CERT_PATH=./certs/localhost.pem
# Optional intermediate / chain file (some providers split this from the leaf cert):
# HTTPS_CA_PATH=./certs/chain.pem
# If the private key is encrypted:
# HTTPS_KEY_PASSPHRASE=your-key-password

# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGDATABASE=your_database
PGUSER=your_user
PGPASSWORD=your_password
# Optional: PGSSLMODE=require

# API authentication (send as: Authorization: Bearer <API_TOKEN>)
API_TOKEN=generate_a_long_random_secret
